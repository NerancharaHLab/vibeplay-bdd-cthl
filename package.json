{
  "name": "vibecode-automate-test-playwright-bdd",
  "version": "1.0.0",
  "description": "BDD Automated Test Suite for Cortex, HLab using Playwright",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:tags": "npx playwright test --grep",
    "test:regression": "npx playwright test --grep @regression",
    "test:functional": "npx playwright test --grep @functional",
    "test:ui": "npx playwright test --grep @ui",
    "allure:generate": "npx allure generate ./allure-results --clean",
    "allure:open": "npx allure open ./allure-report",
    "allure:serve": "npx allure serve ./allure-results",
    "test:site": "node skills/run.js",
    "site:module": "node skills/run.js site:module",
    "site:testcase": "node skills/run.js site:testcase",
    "test:new-cortex:login": "node skills/run.js new-cortex login",
    "test:new-cortex:medical-record": "node skills/run.js new-cortex medical-record",
    "test:new-cortex:opd": "node skills/run.js new-cortex opd",
    "test:new-cortex:ipd": "node skills/run.js new-cortex ipd",
    "test:new-cortex:pharmacy": "node skills/run.js new-cortex pharmacy",
    "test:new-cortex:claim": "node skills/run.js new-cortex claim",
    "test:tmh:login": "node skills/run.js tmh login",
    "test:sbh:login": "node skills/run.js sbh login",
    "test:sbh:registration": "node skills/run.js sbh registration",
    "test:nuh:login": "node skills/run.js nuh login"
  },
  "devDependencies": {
    "@playwright/test": "^1.43.1",
    "@types/node": "^20.12.7",
    "allure-commandline": "^2.42.0",
    "allure-playwright": "^3.9.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "exceljs": "^4.4.0"
  }
}
